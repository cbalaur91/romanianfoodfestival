---
---
<section id="schedule" class="py-20 bg-dark">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-display font-bold text-primary text-center mb-12">
      Festival Schedule
    </h2>
    <div class="max-w-3xl mx-auto">
      <div class="grid gap-8">
        <div class="bg-dark/50 p-6 rounded-lg">
          <h3 class="text-xl font-display font-bold text-primary mb-4">Friday</h3>
          <ul class="space-y-4">
            <li class="flex justify-between items-center">
              <span>Opening Ceremony</span>
              <span class="text-primary">4:00 PM</span>
            </li>
            <li class="flex justify-between items-center">
              <span>Traditional Music Performance</span>
              <span class="text-primary">6:00 PM</span>
            </li>
            <li class="flex justify-between items-center">
              <span>Food Service Ends</span>
              <span class="text-primary">9:00 PM</span>
            </li>
          </ul>
        </div>
        <div class="bg-dark/50 p-6 rounded-lg">
          <h3 class="text-xl font-display font-bold text-primary mb-4">Saturday</h3>
          <ul class="space-y-4">
            <li class="flex justify-between items-center">
              <span>Festival Opens</span>
              <span class="text-primary">11:00 AM</span>
            </li>
            <li class="flex justify-between items-center">
              <span>Folk Dance Performance</span>
              <span class="text-primary">2:00 PM</span>
            </li>
            <li class="flex justify-between items-center">
              <span>Live Music & Dancing</span>
              <span class="text-primary">6:00 PM</span>
            </li>
            <li class="flex justify-between items-center">
              <span>Festival Closes</span>
              <span class="text-primary">10:00 PM</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>