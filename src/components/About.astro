<section id="about" class="py-20 bg-section-gradient">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-secondary via-primary to-tertiary bg-clip-text text-transparent text-center mb-8">
      About Our Festival
    </h2>
    <div class="max-w-3xl mx-auto text-center">
      <p class="mb-6 text-lg backdrop-blur-sm bg-dark/30 p-6 rounded-lg shadow-xl">
        The Romanian Food Festival is an annual celebration of Romanian culture, traditions, and cuisine, 
        hosted by the DESCENT OF THE HOLY SPIRIT & ST. THEODORA OF SIHLA ROMANIAN ORTHODOX CHURCH in Rochester Hills, Michigan.
      </p>
      <p class="mb-6 text-lg backdrop-blur-sm bg-dark/30 p-6 rounded-lg shadow-xl">
        Join us for a weekend filled with authentic Romanian dishes, traditional music, folk dances, 
        and a warm, welcoming atmosphere that brings our community together.
      </p>
      <p class="text-lg backdrop-blur-sm bg-dark/30 p-6 rounded-lg shadow-xl">
        Experience the rich flavors of Romanian cuisine, from our famous sarmale (stuffed cabbage rolls) 
        to mouthwatering cozonac (sweet bread), all prepared with love using traditional family recipes.
      </p>
    </div>
  </div>
</section>