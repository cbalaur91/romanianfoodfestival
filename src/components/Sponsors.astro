---
interface Sponsor {
  name: string;
  logo: string;
  website: string;
}

// Add your sponsors here
const sponsors: Sponsor[] = [
  {
    name: "Example Sponsor 1",
    logo: "https://cdn-icons-png.flaticon.com/512/2103/2103832.png", // Or download and use local path
    website: "https://example1.com",
    attribution: "AI technology icons created by FACH - Flaticon"
  },
  {
    name: "Example Sponsor 2",
    logo: "https://cdn-icons-png.flaticon.com/512/2103/2103832.png",
    website: "https://example2.com"
  }
  // Add more sponsors following the same structure
];

// Duplicate sponsors array to create seamless loop
const allSponsors = [...sponsors, ...sponsors, ...sponsors, ...sponsors, ...sponsors, ...sponsors];
---

<section id="sponsors" class="py-16 bg-section-gradient">
  <div class="w-full px-4 mb-8">
    <h2 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-secondary via-primary to-tertiary bg-clip-text text-transparent text-center">
      Our Sponsors
    </h2>
    <div class="flex justify-center mt-8">
      <a 
        href="/documents/sponsorship-contract.pdf" 
        download
        class="bg-gradient-to-r from-primary to-secondary text-dark px-8 py-3 rounded-full font-semibold hover:opacity-90 transition-opacity shadow-lg flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
        Download Sponsorship Contract
      </a>
    </div>
  </div>
  
  <div class="sponsor-banner relative w-full overflow-hidden">
    <div class="sponsor-scroll flex items-center">
      {allSponsors.map(sponsor => (
        <a
          href={sponsor.website}
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-item flex-shrink-0 mx-12 hover:scale-110 transition-transform duration-300"
        >
          <img
            src={sponsor.logo}
            alt={`${sponsor.name} logo`}
            class="h-16 md:h-24 w-auto object-contain"
            loading="lazy"
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .sponsor-banner {
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .sponsor-scroll {
    animation: scroll 40s linear infinite;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

<script>
  // Adjust scroll speed based on screen width
  const adjustScrollSpeed = () => {
    const scrollElement = document.querySelector('.sponsor-scroll');
    if (scrollElement) {
      const speed = window.innerWidth < 768 ? '30s' : '50s';
      scrollElement.style.animationDuration = speed;
    }
  };

  // Initial adjustment and listen for resize
  adjustScrollSpeed();
  window.addEventListener('resize', adjustScrollSpeed);
</script>