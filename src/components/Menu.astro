---
---
<section id="menu" class="py-20 bg-section-gradient">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-secondary via-primary to-tertiary bg-clip-text text-transparent text-center mb-12">
      Traditional Romanian Menu
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="bg-dark/30 backdrop-blur-sm p-6 rounded-lg shadow-xl border border-primary/20 transition-all duration-300 hover:bg-dark/50 hover:border-primary hover:scale-105 hover:shadow-2xl">
        <h3 class="text-xl font-display font-bold text-primary mb-4">Main Dishes</h3>
        <ul class="space-y-3">
          <li>Sarmale (Stuffed Cabbage Rolls)</li>
          <li>Mici (Grilled Meat Rolls)</li>
          <li>Cozonac (Sweet Bread)</li>
          <li>Mamaliga cu Branza (Polenta with Cheese)</li>
        </ul>
      </div>
      <div class="bg-dark/30 backdrop-blur-sm p-6 rounded-lg shadow-xl border border-primary/20 transition-all duration-300 hover:bg-dark/50 hover:border-primary hover:scale-105 hover:shadow-2xl">
        <h3 class="text-xl font-display font-bold text-primary mb-4">Side Dishes</h3>
        <ul class="space-y-3">
          <li>Salata de Vinete (Eggplant Spread)</li>
          <li>Zacusca (Vegetable Spread)</li>
          <li>Cartofi Copti (Baked Potatoes)</li>
          <li>Muraturi (Pickled Vegetables)</li>
        </ul>
      </div>
      <div class="bg-dark/30 backdrop-blur-sm p-6 rounded-lg shadow-xl border border-primary/20 transition-all duration-300 hover:bg-dark/50 hover:border-primary hover:scale-105 hover:shadow-2xl">
        <h3 class="text-xl font-display font-bold text-primary mb-4">Desserts</h3>
        <ul class="space-y-3">
          <li>Placinta cu Branza (Cheese Pie)</li>
          <li>Gogosi (Romanian Donuts)</li>
          <li>Cozonac (Sweet Bread)</li>
          <li>Various Traditional Pastries</li>
        </ul>
      </div>
    </div>
  </div>
</section>