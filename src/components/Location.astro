---
---
<section id="location" class="py-20 bg-dark/50">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-display font-bold bg-gradient-to-r from-secondary via-primary to-tertiary bg-clip-text text-transparent text-center mb-12">
      Location & Directions
    </h2>
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div class="bg-dark/30 backdrop-blur-sm p-6 rounded-lg shadow-xl border border-primary/20 h-full">
          <h3 class="text-xl font-display font-bold text-primary mb-6">Festival Location</h3>
          <p class="mb-6">1808 School Rd.<br>Rochester Hills, Michigan</p>
          <a 
            href="https://maps.google.com/?q=1808+School+Rd,+Rochester+Hills,+Michigan" 
            target="_blank"
            class="inline-block bg-gradient-to-r from-secondary via-primary to-tertiary text-white px-6 py-2 rounded-full font-semibold hover:opacity-90 transition-opacity shadow-lg"
          >
            Get Directions
          </a>
        </div>
        <div class="bg-dark/30 backdrop-blur-sm p-6 rounded-lg shadow-xl border border-primary/20 h-full">
          <h3 class="text-xl font-display font-bold text-primary mb-6">Parking Information</h3>
          <ul class="space-y-6">
            <li class="flex items-center">
              <span class="w-2 h-2 bg-primary rounded-full mr-3"></span>
              Free parking available on site
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-primary rounded-full mr-3"></span>
              Additional street parking nearby
            </li>
            <li class="flex items-center">
              <span class="w-2 h-2 bg-primary rounded-full mr-3"></span>
              Handicap accessible
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>